{
  "name": "my-potfolio-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/verify-about-studio.mjs && node scripts/ensure-project-previews.mjs",
    "predev": "node scripts/ensure-project-previews.mjs",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/copy-spa-fallback.mjs && node scripts/verify-build.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "verify:about-studio": "node scripts/verify-about-studio.mjs",
    "deploy:netlify": "npm run build && npx netlify-cli deploy --prod --dir=dist"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
